{
  "name": "camoburguer-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/print-bridge",
    "apps/event-simulator",
    "packages/*"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "smoke": "node tests/smoke.mjs",
    "start:api": "npm run start --workspace @camoburguer/api",
    "start:print": "npm run start --workspace @camoburguer/print-bridge",
    "start:sim": "npm run start --workspace @camoburguer/event-simulator",
    "graph:update": "rtk wsl.exe -d Ubuntu -- bash -lc \"bash scripts/graphify-update-wsl.sh\"",
    "graph:extract": "rtk wsl.exe -d Ubuntu -- bash -lc \"graphify extract . --out .\"",
    "graph:extract:code": "rtk wsl.exe -d Ubuntu -- bash -lc \"graphify extract . --out . --code-only\""
  }
}
