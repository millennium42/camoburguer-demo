{
  "name": "camoburguer-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/print-bridge",
    "apps/event-simulator",
    "packages/*"
  ],
  "scripts": {
    "check": "node scripts/check-syntax.mjs",
    "test": "node --test tests/*.test.js",
    "smoke": "node tests/smoke.mjs",
    "start:api": "npm run start --workspace @camoburguer/api",
    "start:print": "npm run start --workspace @camoburguer/print-bridge",
    "start:sim": "npm run start --workspace @camoburguer/event-simulator",
    "graph:update": "bash scripts/graphify-update-wsl.sh",
    "graph:extract": "graphify extract . --out .",
    "graph:extract:code": "graphify extract . --out . --code-only",
    "seed:demo": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
